# OutLayer worker env — MAINNET — self-hosted TDX node.
#
# Copy to the node as `.env.mainnet-worker-tdx` (gitignored) and fill the <SECRET>/<...>
# placeholders. Values are encrypted by the per-node KMS at deploy (vmm-cli --env-file);
# they are NOT baked into the measured compose. NEVER commit the filled file.
# ⚠️ Mainnet = real funds. See docs/mainnet-launch.md before first deploy.
#
# Deploy (name encodes net + worker version + index, see docs/cvm-operations.md):
#   APP_NAME=outlayer-worker-mainnet-0.1.35-1 ENVFILE=worker/.env.mainnet-worker-tdx \
#     ./40-deploy-worker.sh v0.1.35

# --- Coordinator (public API) ---
API_BASE_URL=https://api.outlayer.fastnear.com
API_AUTH_TOKEN=<SECRET: worker API auth token; its sha256 must exist in coordinator worker_auth_tokens>

# --- NEAR (the apiKey query param is a FastNEAR RPC key — treat as secret) ---
NEAR_RPC_URL=https://rpc.mainnet.fastnear.com?apiKey=<RPC_API_KEY>
NEARDATA_API_URL=https://mainnet.neardata.xyz/v0/block/{block_id}?apiKey=<RPC_API_KEY>
FASTNEAR_API_URL=https://api.fastnear.com/status?apiKey=<RPC_API_KEY>
START_BLOCK_HEIGHT=0
OFFCHAINVM_CONTRACT_ID=outlayer.near
OPERATOR_ACCOUNT_ID=worker.outlayer.near        # the register-contract account

# --- TEE registration ---
TEE_MODE=outlayer_tee
USE_TEE_REGISTRATION=true
EXECUTION_ENABLED=true
COMPILATION_ENABLED=false
COMPILATION_MODE=native
ENABLE_EVENT_MONITOR=true

# Init account signs + pays the worker's on-chain registration. MUST equal the contract's
# init_worker_account (verify: get_init_worker_account on OPERATOR_ACCOUNT_ID).
INIT_ACCOUNT_ID=init-worker.outlayer.near
INIT_ACCOUNT_PRIVATE_KEY=<SECRET: ed25519:... full-access key of INIT_ACCOUNT_ID>

# --- Keystore (secret decryption) ---
KEYSTORE_BASE_URL=<keystore base url>
KEYSTORE_AUTH_TOKEN=<SECRET: keystore auth token>

# --- Runtime ---
RUST_LOG=info
WASM_CACHE_MAX_SIZE_MB=300
MAX_EXECUTION_SECONDS_CAP=180
SAVE_SYSTEM_HIDDEN_LOGS_TO_DEBUG=false
PRINT_WASM_STDERR=false
